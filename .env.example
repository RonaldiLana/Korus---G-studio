# ========================================
# ENVIRONMENT VARIABLES - COPY TO .env
# ========================================

# LOCAL DEVELOPMENT (PostgreSQL via Docker)
DATABASE_URL=postgresql://korus:korus123@localhost:5432/korusdb

# PRODUCTION (Render PostgreSQL)
# DATABASE_URL=postgresql://user:password@host:port/database

# Server Configuration
PORT=3000
NODE_ENV=development

# Frontend API URL (Vite will use this in env-based variable)
# Local development (empty = use relative paths)
VITE_API_URL=

# Production (point to your backend API)
# VITE_API_URL=https://korus-backend-a55k.onrender.com

# ========================================
# SETUP INSTRUCTIONS FOR LOCAL DEVELOPMENT
# ========================================
# 
# PREREQUISITES:
# - Node.js 18+ installed
# - Docker installed (for PostgreSQL container)
#
# SETUP STEPS:
# 1. Start PostgreSQL with Docker:
#    docker run --name postgres-korus \
#      -e POSTGRES_USER=korus \
#      -e POSTGRES_PASSWORD=korus123 \
#      -e POSTGRES_DB=korusdb \
#      -p 5432:5432 \
#      -d postgres:15
#
# 2. Create .env file from this example:
#    cp .env.example .env
#
# 3. Install dependencies:
#    npm install --legacy-peer-deps
#
# 4. Start development server:
#    npm run dev
#
# 5. Access application:
#    http://localhost:3000
#
# DATABASE INITIALIZATION:
# - Tables are created automatically on server startup
# - Initial data is seeded automatically
#
# TROUBLESHOOTING:
# - If database won't connect: check if Docker container is running
#    docker ps | grep postgres-korus
# - If port 5432 already in use: change port or stop conflicting service
# - For fresh database: docker rm postgres-korus && run docker run... again
#